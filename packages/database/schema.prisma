// packages/database/schema.prisma
generator client {
  provider = "prisma-client" // Note: v7 uses "prisma-client", not "prisma-client-js"
  output   = "../generated/prisma" // Mandatory in v7 monorepos
}

datasource db {
  provider = "postgresql"
  // url is GONE from here
}
// packages/database/schema.prisma

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique  
  intent    String
  status    String   @default("NEW")
  tenantId String
  appliedConfigId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// packages/database/schema.prisma

model SiteConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  theme     Json     // Stores colors, fonts, and border-radius
  layout    Json     // An array of components: [{ type: 'HERO', content: {...} }]
  updatedAt DateTime @updatedAt
}